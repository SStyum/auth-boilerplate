# ---- Database (Postgres via docker-compose) ----
POSTGRES_USER=authbp
POSTGRES_PASSWORD=authbp
POSTGRES_DB=authbp
POSTGRES_PORT=5432

# DATABASE_URL used by Prisma to connect to Postgres
DATABASE_URL=postgresql://authbp:authbp@localhost:5432/authbp?schema=public

# ---- API (NestJS) ----
API_PORT=3000
NODE_ENV=development

# ---- Auth (JWT) ----
# Generate long, random strings for production: `openssl rand -hex 32`
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=7d

# ---- Refresh token cookie ----
# In production over HTTPS, set SECURE=true and match your public domain
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
# Comma-separated list of allowed origins for CORS + cookie SameSite behavior
WEB_ORIGIN=http://localhost:5173

# ---- Google OAuth ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_CALLBACK_URL exactly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Where to send the user after the OAuth callback finishes
OAUTH_SUCCESS_REDIRECT=http://localhost:5173

# ---- Web (Vite) ----
VITE_API_URL=http://localhost:3000
